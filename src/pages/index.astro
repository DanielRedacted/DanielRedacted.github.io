  { label: 'Truth Social', href: 'https://truthsocial.com/@DanielRedacted', evenodd: true,
    d: 'M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Z M6.5 6.5H17.5V8.7H13.1V17.5H10.9V8.7H6.5Z' },
];
const heroSocials = socials.slice(0, 3);
---

<Base>
  <main class="mx-auto w-full max-w-3xl px-6">
    <!-- Hero -->
    <section class="hero">
      <p class="eyebrow label">Engineer · Founder</p>
      <p class="handle">@DanielRedacted</p>

      <div class="hero-body">
        <img src="/images/avatar.jpg" alt="Daniel" width="96" height="96" class="avatar" />
        <p class="tagline">
          Engineer. I build <a href="https://AP0110.com">AP0110</a>: open-source infrastructure
          for an internet people can own and verify.
        </p>
      </div>

      <div class="btn-row">
        <a class="btn btn-primary" href="mailto:Him@DanielRedacted.net">Email</a>
        <a class="btn btn-ghost" href="https://AP0110.com" target="_blank" rel="noopener">AP0110</a>
      </div>

      <div class="socials">
        {
          heroSocials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" title={s.label} aria-label={s.label}>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={s.d} fill-rule={s.evenodd ? 'evenodd' : null} />
              </svg>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Work -->
    <section id="work">
      <div class="sec-head"><h2>work</h2><span class="idx"><b>01</b> · what I build</span></div>
      <div class="grid">
        <a class="panel card" href="https://AP0110.com" target="_blank" rel="noopener">
          <h3>AP0110 <span class="url">AP0110.com</span></h3>
          <p>
            Co-founding engineer and CEO. AP0110 builds open-source infrastructure for the
            Independent Internet (Web 4.0): AI and digital infrastructure that people and
            institutions can own, verify, and operate for themselves.
          </p>
        </a>

        <a class="panel card" href="https://AP0110.org" target="_blank" rel="noopener">
          <h3>AP0110.ORG <span class="url">AP0110.org</span></h3>
          <p>
            The public research side of the work: a wiki of primary sources, synthesis pages, and
            a knowledge graph tracing the lineage of the Independent Internet. The graph is
            rebuilt from the markdown on every deploy; agents can read the whole site as markdown.
          </p>
        </a>

        <a class="panel card" href="https://CaliforniaCompute.org" target="_blank" rel="noopener">
          <h3>CalCompute <span class="url">CaliforniaCompute.org</span></h3>
          <p>
            President of the UC CalCompute Coalition. CalCompute is California's public AI cloud,
            established by Senate Bill 53: compute infrastructure the public owns and operates,
            instead of only renting it from a handful of companies.
          </p>
        </a>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact">
      <div class="sec-head"><h2>contact</h2><span class="idx"><b>02</b> · email is best</span></div>
      <div class="panel">
        <p style="margin:0">
          <a href="mailto:Him@DanielRedacted.net" class="mono"><strong>Him@DanielRedacted.net</strong></a>
          <button type="button" class="copy" data-copy="Him@DanielRedacted.net">copy</button>
        </p>

        <div class="socials big" style="margin-top:var(--sp-5)">
          {
            socials.map((s) => (
              <a href={s.href} target="_blank" rel="noopener" title={s.label} aria-label={s.label}>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={s.d} fill-rule={s.evenodd ? 'evenodd' : null} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <footer class="foot">
      <span>Daniel <span class="redacted">Redacted</span></span>
      <span>danielredacted.net</span>
    </footer>
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(btn.dataset.copy ?? '');
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = 'copy'), 1500);
      });
    });
  </script>
</Base>
